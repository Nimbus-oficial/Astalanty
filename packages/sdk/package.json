    "check": "pnpm build && pnpm lint && pnpm test",
    "format": "echo \"No formatter configured for @astalanty/sdk\""
  },
  "dependencies": {
    "ethers": "^6.17.0"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  }
