  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.1.0",
    "chai": "^6.2.2",
    "dotenv": "^17.4.2",
    "ethers": "^6.17.0",
    "hardhat": "^2.26.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.3.0"
  }
}
