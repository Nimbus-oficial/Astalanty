{
  "name": "@astalanty/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "deploy:local": "hardhat run scripts/deploy-mvp.cjs",
    "deploy:arbitrum-sepolia": "hardhat run scripts/deploy-mvp.cjs --network arbitrumSepolia",
